-- SERVICES
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer

-- SETTINGS
local AIM = true
local target = nil

-- 🎯 TÌM NPC GẦN NHẤT
local function getClosestNPC()
	local closest, dist = nil, math.huge
	
	for _,v in pairs(workspace:GetDescendants()) do
		if v:IsA("Model")
		and v:FindFirstChild("HumanoidRootPart")
		and v:FindFirstChild("Humanoid")
		and v.Humanoid.Health > 0
		and not Players:GetPlayerFromCharacter(v) then
			
			local d = (player.Character.HumanoidRootPart.Position - v.HumanoidRootPart.Position).Magnitude
			
			if d < dist then
				dist = d
				closest = v
			end
		end
	end
	
	return closest
end

-- 🔄 AUTO UPDATE TARGET
task.spawn(function()
	while true do
		task.wait(0.5)
		
		local char = player.Character
		if not char or not char:FindFirstChild("HumanoidRootPart") then continue end
		
		-- nếu target chết hoặc mất
		if not target 
		or not target:FindFirstChild("Humanoid")
		or target.Humanoid.Health <= 0 then
			
			target = getClosestNPC()
		end
		
		-- nếu không có NPC → tắt
		if not target then
			AIM = false
		else
			AIM = true
		end
	end
end)

-- 🎯 AIM MƯỢT (KHÔNG XOAY CAMERA)
RunService.RenderStepped:Connect(function()
	if AIM and target and target:FindFirstChild("HumanoidRootPart") then
		
		local char = player.Character
		if not char or not char:FindFirstChild("HumanoidRootPart") then return end
		
		local root = char.HumanoidRootPart
		local tRoot = target.HumanoidRootPart
		
		-- xoay mượt
		root.CFrame = root.CFrame:Lerp(
			CFrame.new(root.Position, tRoot.Position),
			0.25
		)
	end
end)

-- 🔘 GUI NHỎ
local gui = Instance.new("ScreenGui", game.CoreGui)

local label = Instance.new("TextLabel", gui)
label.Size = UDim2.new(0,200,0,50)
label.Position = UDim2.new(0,10,0,200)
label.BackgroundColor3 = Color3.fromRGB(30,30,30)
label.TextColor3 = Color3.new(1,1,1)
label.Font = Enum.Font.GothamBold
label.TextScaled = true

-- UPDATE TEXT
task.spawn(function()
	while true do
		task.wait(0.2)
		
		if AIM and target then
			label.Text = "AIM: "..target.Name
		elseif not target then
			label.Text = "AIM: WAITING NPC..."
		else
			label.Text = "AIM: OFF"
		end
	end
end)
